---
import BaseLayout from '../../layouts/BaseLayout.astro';
const pageTitle = "The Route";

const TIMELAPSE_VIDEO_ID = "dQw4w9WgXcQ"; 
---

<BaseLayout pageTitle={pageTitle}>
  
  <section class="py-16 max-w-3xl mx-auto text-center">
    <!-- Changed text-stone-400 to text-text-light -->
    <span class="text-[10px] tracking-widest uppercase font-sans block mb-3" style="color: var(--color-text-light);">The Journey</span>
    <!-- Changed text-stone-600 to text-text-muted -->
    <p class="font-sans text-sm text-text-muted leading-relaxed max-w-xl mx-auto m-0">
      Located in the rugged heart of the Valle de Guadalupe, perched between Tecate and Ensenada. Watch our cinematic route preview below to prepare for your arrival.
    </p>
  </section>

  <section class="max-w-5xl mx-auto mb-16 px-2">
    <!-- Changed border-stone-200/60 to border-border-main -->
    <div class="relative w-full aspect-video bg-black shadow-md border border-border-main overflow-hidden">
      <iframe
        class="absolute top-0 left-0 w-full h-full"
        src={`https://www.youtube.com/embed/${TIMELAPSE_VIDEO_ID}?rel=0&modestbranding=1`}
        title="Casa Toro Route Timelapse"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
    <div class="mt-4 text-center">
      <!-- Changed text-stone-500 to text-text-muted -->
      <span class="text-[11px] font-serif italic text-text-muted">
        Route Preview: Scenic Highway 3 into the Boulder Highlands
      </span>
    </div>
  </section>

  <!-- Changed border-stone-200/60 to border-border-main -->
  <section class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto border-t border-border-main pt-12 pb-16 font-sans">
    
    <div class="space-y-6">
      <div>
        <!-- Changed text-stone-400 to text-text-light -->
        <h3 class="text-xs uppercase tracking-widest text-text-light font-bold mt-0 mb-2">From Tecate (The North Route)</h3>
        <!-- Changed text-stone-600 to text-text-muted -->
        <p class="text-sm text-text-muted leading-loose m-0">
          Take Federal Highway 3 South towards Ensenada. You will wind down through spectacular high-desert valleys. Keep a watch out for the boulder markers near kilometer marker 68, where you will exit onto our private unpaved trail.
        </p>
      </div>
      <div>
        <!-- Changed text-stone-400 to text-text-light -->
        <h3 class="text-xs uppercase tracking-widest text-text-light font-bold mt-0 mb-2">From Ensenada (The Coast Route)</h3>
        <!-- Changed text-stone-600 to text-text-muted -->
        <p class="text-sm text-text-muted leading-loose m-0">
          Head North on Federal Highway 3 entering the Valle de Guadalupe. Pass through the main wine tasting village corridors. As the road climbs up towards the mountain ridges, look for our private entrance gate flanking the left horizon.
        </p>
      </div>
    </div>

    <!-- Changed bg-stone-50 to bg-bg-surface and border-stone-200/40 to border-border-main -->
    <div class="bg-bg-surface border border-border-main p-8 space-y-4">
      <!-- Changed text-stone-800 to text-text-main -->
      <h3 class="text-xs uppercase tracking-widest text-text-main font-bold mt-0 mb-1">Traveler Advisory</h3>
      <!-- Changed text-stone-600 to text-text-muted -->
      <p class="text-xs text-text-muted leading-loose m-0">
        While Highway 3 is smoothly paved, the final 1.5 kilometers approaching Casa Toro consists of a graded, rustic dirt mountain trail to maintain total isolation.
      </p>
      <!-- Changed border-stone-200/60 to border-border-main -->
      <div class="pt-4 border-t border-border-main flex items-center justify-between">
        <!-- Changed text-stone-400 to text-text-light -->
        <span class="text-[11px] uppercase tracking-wider text-text-light font-semibold">Recommended Vehicle</span>
        <!-- Changed text-stone-800 to text-text-main -->
        <span class="text-xs font-semibold text-text-main">Crossover / SUV or Dual-Sport Bike</span>
      </div>
    </div>

  </section>

</BaseLayout>