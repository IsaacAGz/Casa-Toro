---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "The Route — Casa Toro";

// Replace this placeholder with your actual YouTube video ID once you upload your timelapse!
const TIMELAPSE_VIDEO_ID = "dQw4w9WgXcQ"; 
---

<BaseLayout pageTitle={pageTitle}>
  
  <section class="py-16 max-w-3xl mx-auto text-center">
    <span class="text-[10px] tracking-widest uppercase text-stone-400 font-sans block mb-3">The Journey</span>
    <h1 class="font-serif text-4xl md:text-5xl font-light tracking-wide text-stone-900 m-0 mb-6 uppercase">
      Finding Casa Toro
    </h1>
    <p class="font-sans text-sm text-stone-600 leading-relaxed max-w-xl mx-auto m-0">
      Located in the rugged heart of the Valle de Guadalupe, perched between Tecate and Ensenada. Watch our cinematic route preview below to prepare for your arrival.
    </p>
  </section>

  <section class="max-w-5xl mx-auto mb-16 px-2">
    <div class="relative w-full aspect-video bg-stone-950 shadow-md border border-stone-200/60 overflow-hidden">
      <iframe
        class="absolute top-0 left-0 w-full h-full"
        src={`https://www.youtube.com/embed/${TIMELAPSE_VIDEO_ID}?rel=0&modestbranding=1`}
        title="Casa Toro Route Timelapse"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
    <div class="mt-4 text-center">
      <span class="text-[11px] font-serif italic text-stone-500">
        Route Preview: Scenic Highway 3 into the Boulder Highlands
      </span>
    </div>
  </section>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto border-t border-stone-200/60 pt-12 pb-16 font-sans">
    
    <div class="space-y-6">
      <div>
        <h3 class="text-xs uppercase tracking-widest text-stone-400 font-bold mt-0 mb-2">From Tecate (The North Route)</h3>
        <p class="text-sm text-stone-600 leading-loose m-0">
          Take Federal Highway 3 South towards Ensenada. You will wind down through spectacular high-desert valleys. Keep a watch out for the boulder markers near kilometer marker 68, where you will exit onto our private unpaved trail.
        </p>
      </div>
      <div>
        <h3 class="text-xs uppercase tracking-widest text-stone-400 font-bold mt-0 mb-2">From Ensenada (The Coast Route)</h3>
        <p class="text-sm text-stone-600 leading-loose m-0">
          Head North on Federal Highway 3 entering the Valle de Guadalupe. Pass through the main wine tasting village corridors. As the road climbs up towards the mountain ridges, look for our private entrance gate flanking the left horizon.
        </p>
      </div>
    </div>

    <div class="bg-stone-50 border border-stone-200/40 p-8 space-y-4">
      <h3 class="text-xs uppercase tracking-widest text-stone-800 font-bold mt-0 mb-1">Traveler Advisory</h3>
      <p class="text-xs text-stone-600 leading-loose m-0">
        While Highway 3 is smoothly paved, the final 1.5 kilometers approaching Casa Toro consists of a graded, rustic dirt mountain trail to maintain total isolation.
      </p>
      <div class="pt-4 border-t border-stone-200/60 flex items-center justify-between">
        <span class="text-[11px] uppercase tracking-wider text-stone-400 font-semibold">Recommended Vehicle</span>
        <span class="text-xs font-semibold text-stone-800">Crossover / SUV or Dual-Sport Bike</span>
      </div>
    </div>

  </section>

</BaseLayout>