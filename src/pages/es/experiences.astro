---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceGrid from '../../components/ExperienceGrid.vue';
const pageTitle = "Experiences"
---

<BaseLayout pageTitle={pageTitle}>
	<!-- Hero Section -->
	<header class="py-20 text-center max-w-4xl mx-auto border-b border-stone-200">
		<span class="text-xs tracking-widest font-sans uppercase text-stone-500 block mb-3">
			Baja California, Mexico
		</span>
		<h1 class="text-5xl md:text-6xl font-serif font-light text-stone-900 tracking-wide m-0">
			RETIRO RUSTICO, LUJO REFINADO
		</h1>
		<p class="mt-6 text-stone-600 max-w-xl mx-auto font-sans text-sm md:text-base leading-relaxed">
			Un retiro moderno ubicado entre las colinas rocosa entre Tecate y Ensenada
		</p>
	</header>

	<!-- Interactive Experiences Component Section -->
	<main>
    	<ExperienceGrid client:visible />
	</main>
</BaseLayout>
