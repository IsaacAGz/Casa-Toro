---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceGridEs from '../../components/ExperienceGridEs.vue';

const pageTitle = "Casa Toro — Refugio de Lujo Rústico";
---

<BaseLayout pageTitle={pageTitle}>
  
  <!-- --- SECCIÓN HERO --- -->
  <section class="pt-16 pb-20 text-center max-w-4xl mx-auto">
    <div class="flex items-center justify-center gap-3 mb-4">
      <!-- Using custom border variable colors for the accent lines -->
      <span class="w-8 h-px" style="background-color: var(--color-border-main);"></span>
      <span class="text-[10px] tracking-widest uppercase font-sans font-semibold" style="color: var(--color-text-light);">
        Valle de Guadalupe, B.C.
      </span>
      <span class="w-8 h-px" style="background-color: var(--color-border-main);"></span>
    </div>
    
    <!-- Title and text colors updated to rely entirely on CSS variables -->
    <h1 class="font-serif text-5xl md:text-7xl font-light tracking-wide m-0 mb-6 uppercase" style="color: var(--color-text-title);">
      Casa Toro
    </h1>

    <p class="font-serif italic text-lg md:text-xl leading-relaxed max-w-2xl mx-auto m-0" style="color: var(--color-text-muted);">
      "Donde el minimalismo arquitectónico puro se encuentra con el alma rústica y cálida de la zona vinícola más importante de México."
    </p>
  </section>

  <!-- --- MATRIZ DE RESUMEN DEL REFUGIO --- -->
  <!-- Borders adjusted to use var(--color-border-main) natively -->
  <section 
    class="grid grid-cols-1 md:grid-cols-3 gap-8 py-10 my-12 font-sans"
    style="border-top: 1px solid var(--color-border-main); border-b: 1px solid var(--color-border-main);"
  >
    <div class="text-center md:text-left">
      <h4 class="text-[11px] uppercase tracking-widest font-bold m-0 mb-1" style="color: var(--color-text-light);">
        El Entorno
      </h4>
      <p class="text-sm m-0 leading-relaxed" style="color: var(--color-text-muted);">
        Situado sobre colinas de granito privado flanqueadas por antiguos viñedos entre Tecate y Ensenada.
      </p>
    </div>
    
    <!-- Middle block border dividers synced with the variable canvas color context -->
    <div 
      class="text-center md:text-left border-y md:border-y-0 md:border-x py-6 md:py-0 md:px-8"
      style="border-color: var(--color-border-main);"
    >
      <h4 class="text-[11px] uppercase tracking-widest font-bold m-0 mb-1" style="color: var(--color-text-light);">
        El Santuario
      </h4>
      <p class="text-sm m-0 leading-relaxed" style="color: var(--color-text-muted);">
        Diseñado con imponentes muros de concreto, maderas curadas, jacuzzi infinito de piedra y terraza de observación estelar.
      </p>
    </div>
    
    <div class="text-center md:text-left md:pl-4">
      <h4 class="text-[11px] uppercase tracking-widest font-bold m-0 mb-1" style="color: var(--color-text-light);">
        El Horizonte
      </h4>
      <p class="text-sm m-0 leading-relaxed" style="color: var(--color-text-muted);">
        Acceso inmediato a rutas de motociclismo de montaña, campos de arquería tradicional y zonas de tiro deportivo.
      </p>
    </div>
  </section>

  <!-- --- CUADRÍCULA DE EXPERIENCIAS EN ESPAÑOL --- -->
  <ExperienceGridEs client:visible />

</BaseLayout>