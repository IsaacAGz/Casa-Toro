---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ExperienceGridEs from '../../components/ExperienceGridEs.vue';

const pageTitle = "Casa Toro — Refugio de Lujo Rústico";
---

<BaseLayout pageTitle={pageTitle}>
  
  <!-- --- SECCIÓN HERO --- -->
  <section class="pt-16 pb-20 text-center max-w-4xl mx-auto">
    <div class="flex items-center justify-center gap-3 mb-4">
      <span class="w-8 h-px bg-stone-300"></span>
      <span class="text-[10px] tracking-widest uppercase text-stone-400 font-sans font-semibold">
        Valle de Guadalupe, B.C.
      </span>
      <span class="w-8 h-px bg-stone-300"></span>
    </div>
    
    <h1 class="font-serif text-5xl md:text-7xl font-light tracking-wide text-stone-900 m-0 mb-6 uppercase">
      Casa Toro
    </h1>

    <p class="font-serif italic text-lg md:text-xl text-stone-600 leading-relaxed max-w-2xl mx-auto m-0">
      "Donde el minimalismo arquitectónico puro se encuentra con el alma rústica y cálida de la zona vinícola más importante de México."
    </p>
  </section>

  <!-- --- MATRIZ DE RESUMEN DEL REFUGIO --- -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-8 border-t border-b border-stone-200/60 py-10 my-12 font-sans">
    <div class="text-center md:text-left">
      <h4 class="text-[11px] uppercase tracking-widest text-stone-400 font-bold m-0 mb-1">El Entorno</h4>
      <p class="text-sm text-stone-700 m-0 leading-relaxed">Situado sobre colinas de granito privado flanqueadas por antiguos viñedos entre Tecate y Ensenada.</p>
    </div>
    <div class="text-center md:text-left border-y md:border-y-0 md:border-x border-stone-200/40 py-6 md:py-0 md:px-8">
      <h4 class="text-[11px] uppercase tracking-widest text-stone-400 font-bold m-0 mb-1">El Santuario</h4>
      <p class="text-sm text-stone-700 m-0 leading-relaxed">Diseñado con imponentes muros de concreto, maderas curadas, jacuzzi infinito de piedra y terraza de observación estelar.</p>
    </div>
    <div class="text-center md:text-left md:pl-4">
      <h4 class="text-[11px] uppercase tracking-widest text-stone-400 font-bold m-0 mb-1">El Horizonte</h4>
      <p class="text-sm text-stone-700 m-0 leading-relaxed">Acceso inmediato a rutas de motociclismo de montaña, campos de arquería tradicional y zonas de tiro deportivo.</p>
    </div>
  </section>

  <!-- --- CUADRÍCULA DE EXPERIENCIAS EN ESPAÑOL --- -->
  <ExperienceGridEs client:visible />

</BaseLayout>