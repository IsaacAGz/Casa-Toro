---
import BaseLayout from '../layouts/BaseLayout.astro';
const allExperiences = Object.values(import.meta.glob('./content/*.md', { eager: true}));
const pageTitle = "Experiences"
---

<BaseLayout pageTitle={pageTitle}>
	<p>Read all about all of the experiences available when you visit us.</p>
	<ul>
		{allExperiences.map((post: any) => <li><a href={post.url}>post.frontmatter.title</a></li>)}
	</ul>
</BaseLayout>
