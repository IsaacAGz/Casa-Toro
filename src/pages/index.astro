---
// src/pages/index.astro
// This is the absolute root page layout (/). 
// It remains completely empty of HTML content because its sole purpose is handling routing.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, follow" />
    <title>Redirecting...</title>

    <script is:inline>
      // 1. Sniff out the browser's preferred language settings list
      const userLang = navigator.language || navigator.userLanguage || 'en';
      
      // 2. Clean the string token to grab just the primary country letters (e.g., 'es-MX' becomes 'es')
      const primaryLang = userLang.toLowerCase().split('-')[0];

      // 3. Direct the client window cleanly to the corresponding directory pathway
      if (primaryLang === 'es') {
        window.location.replace('/es/');
      } else {
        // Fallback default language is English if preference is anything else
        window.location.replace('/en/');
      }
    </script>
  </head>
  <body>
    <!-- 
      Safe fallback link row: In the rare event a traveler has JavaScript completely disabled 
      in their secure browser window, they can still navigate manually.
    -->
    <noscript>
      <div style="font-family: sans-serif; text-align: center; margin-top: 10rem; color: #444;">
        <p>Please choose your language / Por favor seleccione su idioma:</p>
        <a href="/en/" style="margin-right: 1.5rem; color: #000; font-weight: bold;">English</a>
        <a href="/es/" style="color: #000; font-weight: bold;">Español</a>
      </div>
    </noscript>
  </body>
</html>