---
// src/components/Navigation.astro
const { pathname } = Astro.url;
const langPrefix = pathname.startsWith('/es') ? '/es' : '/en';

// Define translated path links arrays dynamically
const links = langPrefix === '/es' 
  ? [
      { href: `${langPrefix}/`, label: 'Inicio' },
      { href: `${langPrefix}/about`, label: 'Nosotros' },
      { href: `${langPrefix}/location`, label: 'Ruta' },
      { href: `${langPrefix}/reviews`, label: 'Reseñas' },
      { href: `${langPrefix}/experiences`, label: 'Experiencias' }
    ]
  : [
      { href: `${langPrefix}/`, label: 'Home' },
      { href: `${langPrefix}/about`, label: 'About' },
      { href: `${langPrefix}/location`, label: 'Location' },
      { href: `${langPrefix}/reviews`, label: 'Reviews' },
      { href: `${langPrefix}/experiences`, label: 'Experiences' }
    ];
---

<div class="nav-links">
  {links.map(link => (
    <a href={link.href}>{link.label}</a>
  ))}
</div>