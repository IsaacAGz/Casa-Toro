---
// src/components/Header.astro
import Menu from './Menu.astro';
import Navigation from './Navigation.astro';
import ThemeIcon from './ThemeIcon.astro';
import LangToggle from './LangToggle.astro';
---

<header class="border-b border-stone-200/60 bg-transparent w-full">
  <nav class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between py-4 md:py-6">
    <div class="flex items-center justify-between w-full md:w-auto">
      <a href="/" class="font-serif text-lg tracking-widest text-stone-900 hover:text-stone-700 uppercase font-medium">
        Casa Toro
      </a>
      <div class="flex items-center gap-3">
        <ThemeIcon />
        <LangToggle /> 
        <Menu />
      </div>
    </div>
    <Navigation />
  </nav>
</header>