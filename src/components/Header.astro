---
// src/components/Header.astro
import Menu from './Menu.astro';
import Navigation from './Navigation.astro';
import ThemeIcon from './ThemeIcon.astro';
import LangToggle from './LangToggle.astro';
---

<header class="w-full bg-transparent" style="border-bottom: 1px solid var(--color-border-main);">
  <nav class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between py-4 md:py-6">
    <div class="flex items-center justify-between w-full md:w-auto">
      <a 
        href="/" 
        class="font-serif text-lg tracking-widest uppercase font-medium transition-colors duration-200"
        style="color: var(--color-text-main); font-family: var(--font-serif);"
        onmouseover="this.style.color='var(--color-accent)'"
        onmouseout="this.style.color='var(--color-text-main)'"
      >
        Casa Toro
      </a>
      <div class="flex items-center gap-3">
        <ThemeIcon />
        <LangToggle /> 
        <Menu />
      </div>
    </div>
    <Navigation />
  </nav>
</header>